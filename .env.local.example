# Base de données — Neon PostgreSQL
# Copier l'URL depuis console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/toss-by-toss?sslmode=require"

# Cloudinary — console.cloudinary.com
CLOUDINARY_CLOUD_NAME="votre_cloud_name"
CLOUDINARY_API_KEY="votre_api_key"
CLOUDINARY_API_SECRET="votre_api_secret"

# Resend — resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Genius Pay — portail développeur Genius Pay
GENIUSPAY_API_KEY="votre_clé_api"
GENIUSPAY_SECRET="votre_secret"
GENIUSPAY_WEBHOOK_SECRET="votre_webhook_secret"

# URL du site (production : votre domaine Vercel)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
